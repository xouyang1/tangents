---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>{SITE_TITLE}</h1>
			<p>
				Useful artifacts from problems I was already solving. New posts whenever
				something comes together.
			</p>
			<p>
				A water filter comparison table one month, a product framework the next.
				Wherever the tangent goes.
			</p>
			<p>
				<a href="/blog">Read the blog &rarr;</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
